{
  "name": "personal-server-backend",
  "version": "0.0.1",
  "description": "",
  "engines": {
    "node": "22.12.0"
  },
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "env-cmd -f ./.env.dev nest start",
    "start:dev": "nest build && env-cmd -f ./.env.dev nest start --watch",
    "start:debug": "env-cmd -f ./.env.dev nest start --debug --watch",
    "start:prod": "node dist/main",
    "dist": "sh ./dist.sh",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typeorm": "env-cmd -f ./.env.dev ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js --config src/typeormconfig.ts",
    "typeorm:migrate:gen": "set NODE_OPTIONS=-r tsconfig-paths/register && env-cmd -f ./.env.dev typeorm-ts-node-commonjs migration:generate -d ./src/dataSource.ts",
    "typeorm:migrate:run": "set NODE_OPTIONS=-r tsconfig-paths/register && env-cmd -f ./.env.dev typeorm-ts-node-commonjs migration:run -d ./src/dataSource.ts",
    "typeorm:migrate:drop": "env-cmd -f ./.env.dev ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js --config src/typeormconfig.ts schema:drop",
    "typeorm:migrate:run:prod": "set NODE_OPTIONS=-r tsconfig-paths/register && env-cmd -f ./.env typeorm-ts-node-commonjs migration:run -d ./src/dataSource.ts",
    "typeorm:schema:drop:prod": "./node_modules/typeorm/cli.js --config dist/typeormconfig.js schema:drop",
    "typeorm:migration:revert": "env-cmd -f ./.env.dev  ./node_modules/typeorm/cli.js --config dist/typeormconfig.js migration:revert",
    "test": "env-cmd -f ./.env.dev jest",
    "test:verbose": "jest --verbose",
    "test:watch": "jest --watch",
    "test:cov": "jest -w 1 --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "NODE_ENV=testing env-cmd -f ./.env.dev jest --runInBand --config ./test/jest-e2e.json",
    "fixtures": "env-cmd -f ./.env.dev fixtures ./src/fixtures --config ./src/typeormconfig.ts --require ts-node/register --require=tsconfig-paths/register"
  },
  "dependencies": {
    "@nestjs/common": "^9.4.3",
    "@nestjs/config": "^2.3.4",
    "@nestjs/core": "^9.4.3",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^9.4.3",
    "@nestjs/platform-socket.io": "^9.4.3",
    "@nestjs/schedule": "^3.0.4",
    "@nestjs/swagger": "^7.0.12",
    "@nestjs/typeorm": "^9.0.1",
    "@nestjs/websockets": "^9.4.3",
    "@nestjsx/crud": "^5.0.0-alpha.3",
    "@nestjsx/crud-typeorm": "^5.0.0-alpha.3",
    "@types/axios": "^0.14.4",
    "aws-sdk": "^2.1073.0",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.4.1",
    "body-parser": "^1.20.2",
    "cache-manager": "^4.1.0",
    "class-transformer": "^0.4.0",
    "class-validator": "^0.13.1",
    "compression": "^1.8.1",
    "deepmerge": "^4.2.2",
    "express-http-context": "^1.2.4",
    "js-sha512": "^0.9.0",
    "jsonwebtoken": "^8.5.1",
    "nest-transact": "^9.1.2",
    "node-fetch": "^2.6.6",
    "pg": "^8.6.0",
    "qrcode": "^1.5.4",
    "qrcode-svg": "^1.1.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^3.0.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.7.5",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^4.1.6",
    "typeorm": "^0.3.20",
    "xlsx": "^0.16.9",
    "xml2js": "^0.6.2",
    "zip-dir": "^2.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^7.6.0",
    "@nestjs/schematics": "^7.3.0",
    "@nestjs/testing": "^9.4.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/deepmerge": "^2.2.0",
    "@types/express": "^4.17.12",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.5",
    "@types/node": "^14.17.1",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^2.0.10",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^4.25.0",
    "@typescript-eslint/parser": "^4.25.0",
    "chai": "^4.3.4",
    "chai-json-pattern": "^1.1.0",
    "env-cmd": "^10.1.0",
    "eslint": "^7.27.0",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-prettier": "^3.3.1",
    "jest": "^29.7.0",
    "prettier": "2.8.8",
    "supertest": "^6.1.3",
    "ts-jest": "^29.2.6",
    "ts-loader": "^8.3.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^3.9.0",
    "typeorm-fixtures-cli": "^4.0.0",
    "typescript": "^4.2.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    }
  }
}
